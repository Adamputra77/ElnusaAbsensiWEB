{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "Information about Warehouse ELNUSA BSD employees",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier (NIK)" },
        "name": { "type": "string", "description": "Full name of the employee" },
        "department": { "type": "string", "description": "Employee department" },
        "nik": { "type": "string", "description": "National Identification Number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "department", "nik"]
    },
    "PresenceLog": {
      "title": "Presence Log",
      "description": "Log of employee scan activity",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["IN", "OUT"] },
        "date": { "type": "string", "description": "YYYY-MM-DD" }
      },
      "required": ["employeeId", "timestamp", "type", "date"]
    },
    "SystemConfig": {
      "title": "System Config",
      "description": "Global system settings",
      "type": "object",
      "properties": {
        "maintenanceMode": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "message": { "type": "string" }
      }
    },
    "DailyStats": {
      "title": "Daily Stats",
      "description": "Daily summary of attendance",
      "type": "object",
      "properties": {
        "in": { "type": "number" },
        "out": { "type": "number" },
        "pob": { "type": "number", "description": "Personnel On Board (Currently In)" },
        "totalVisits": { "type": "number" }
      },
      "required": ["in", "out", "pob", "totalVisits"]
    }
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employees"
    },
    "/presence_logs/{logId}": {
      "schema": "PresenceLog",
      "description": "Historical scan logs"
    },
    "/system_config/{configId}": {
      "schema": "SystemConfig",
      "description": "Global configuration document"
    },
    "/stats/{date}": {
      "schema": "DailyStats",
      "description": "Real-time daily stats for counters"
    }
  }
}
